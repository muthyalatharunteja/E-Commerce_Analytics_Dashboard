      <aliases enabled='yes' />
      <column caption='Delivery Delay Gap' datatype='integer' name='[Calculation_1338413576734007296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,&#10;    DATE([order_estimated_delivery_date]),&#10;    DATE([order_delivered_customer_date])&#10;)' />
      </column>
      <column caption='Delay Percentage' datatype='real' name='[Calculation_1338413576734908417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [delivery_status] = &quot;Delayed&quot; THEN 1 ELSE 0 END)&#10;/ COUNT([order_id])' />
      </column>
      <column caption='Delay Category' datatype='string' name='[Calculation_1338413576738254850]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1338413576734007296] &lt;= 0 THEN &quot;On Time&quot;&#10;ELSEIF [Calculation_1338413576734007296] &lt;= 2 THEN &quot;1-2 Days Late&quot;&#10;ELSEIF [Calculation_1338413576734007296] &lt;= 5 THEN &quot;3-5 Days Late&quot;&#10;ELSE &quot;5+ Days Late&quot;&#10;END' />
      </column>
      <column caption='delivery status_new' datatype='string' name='[Calculation_1364520380846141440]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1338413576734007296] &lt;= 0 THEN &quot;On Time&quot;&#10;ELSE &quot;Delayed&quot;&#10;END' />
      </column>
      <column caption='flag vs outlier' datatype='string' name='[Calculation_1391260503649083392]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &gt; 60 THEN &quot;Outlier&quot;&#10;ELSE &quot;Normal&quot;&#10;END' />
      </column>
