    <worksheet name='Time Analysis Heat map '>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontname='Tableau Medium' fontsize='10'>Time Analysis — Peak Activity During Daytime Hour</run>
            <run bold='true' fontcolor='#4e79a7' fontname='Tableau Medium' fontsize='8'>s</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>Customer activity peaks during daytime hours, particularly around midday.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>-This indicates that customers are most engaged during working hours, making it the optimal time for marketing campaigns and promotions.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='time_analysis' name='federated.0owikjx0tosxor1e8yawk004fey3' />
          </datasources>
          <datasource-dependencies datasource='federated.0owikjx0tosxor1e8yawk004fey3'>
            <column caption='Days' datatype='string' name='[day_name]' role='dimension' type='nominal' />
