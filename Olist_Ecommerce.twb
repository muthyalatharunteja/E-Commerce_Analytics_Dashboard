          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.19t9x3l1xvg8pq10acn0q011uv0k].[my:cohort_month:ok]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.19t9x3l1xvg8pq10acn0q011uv0k].[sum:customers:qk]' shelf='rows' />
