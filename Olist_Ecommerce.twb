    <worksheet name='Cohort Heatmap'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontname='Tableau Medium' fontsize='10'>Cohort Analysis — Low Customer Retention After First Purchas</run>
            <run bold='true' fontcolor='#898989' fontsize='8'>e</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>🔵High value (first month, many customers) 🔴Low values (retention drops)</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>-Customer retention drops sharply after the first purchase.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>-Most customers do not return in subsequent months, indicating a major retention challenge.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Medium' fontsize='8'>🔴 Red → High value (first month, many customers) 🔵 Blue → Low values (retention drops)</run>
            <run>
Sum of Customers (color) broken down by Month Number vs. Cohort Month (MY). The view is filtered on Month Number and Cohort Month (MY). The Month Number filter keeps 13 of 20 members. The Cohort Month (MY) filter keeps 23 of 23 members.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='kpi_cohort_analysis' name='federated.19t9x3l1xvg8pq10acn0q011uv0k' />
          </datasources>
          <datasource-dependencies datasource='federated.19t9x3l1xvg8pq10acn0q011uv0k'>
            <column caption='Cohort Month' datatype='date' name='[cohort_month]' role='dimension' type='ordinal' />
            <column caption='Customers' datatype='integer' name='[customers]' role='measure' type='quantitative' />
            <column caption='Month Number' datatype='integer' name='[month_number]' role='dimension' type='quantitative' />
            <column-instance column='[cohort_month]' derivation='MY' name='[my:cohort_month:ok]' pivot='key' type='ordinal' />
            <column-instance column='[month_number]' derivation='None' name='[none:month_number:ok]' pivot='key' type='ordinal' />
            <column-instance column='[customers]' derivation='Sum' name='[sum:customers:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.19t9x3l1xvg8pq10acn0q011uv0k].[none:month_number:ok]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:month_number:ok]' member='0' />
              <groupfilter function='member' level='[none:month_number:ok]' member='1' />
              <groupfilter function='member' level='[none:month_number:ok]' member='2' />
              <groupfilter function='member' level='[none:month_number:ok]' member='3' />
