    <worksheet name='Data Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontname='Tableau Medium' fontsize='10'>&lt;Sheet Name&gt;</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontsize='8'>- Most deliveries are completed within 5–15 days, but a long tail of extreme delays indicates operational inefficiencies or data anomalies.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='8'>🔵 </run>
            <run fontcolor='#898989' fontsize='8'>Normal = Delivery ≤ 60 days &amp; </run>
            <run fontcolor='#000000' fontsize='8'>🟠 </run>
            <run fontcolor='#898989' fontsize='8'>Outlier = Delivery &gt; 60 days </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='kpi_delivery_performance' name='federated.1cqwvyq0ibt9o216sbkq603qjvkn' />
          </datasources>
          <datasource-dependencies datasource='federated.1cqwvyq0ibt9o216sbkq603qjvkn'>
            <column caption='Delivery Delay Gap' datatype='integer' name='[Calculation_1338413576734007296]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,&#10;    DATE([order_estimated_delivery_date]),&#10;    DATE([order_delivered_customer_date])&#10;)' />
            </column>
            <column caption='delivery status_new' datatype='string' name='[Calculation_1364520380846141440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1338413576734007296] &lt;= 0 THEN &quot;On Time&quot;&#10;ELSE &quot;Delayed&quot;&#10;END' />
            </column>
            <column caption='flag vs outlier' datatype='string' name='[Calculation_1391260503649083392]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [delivery_days] &gt; 60 THEN &quot;Outlier&quot;&#10;ELSE &quot;Normal&quot;&#10;END' />
            </column>
            <column-instance column='[order_id]' derivation='Count' name='[cnt:order_id:qk]' pivot='key' type='quantitative' />
            <column caption='Delivery Days' datatype='integer' name='[delivery_days]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1364520380846141440]' derivation='None' name='[none:Calculation_1364520380846141440:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1391260503649083392]' derivation='None' name='[none:Calculation_1391260503649083392:nk]' pivot='key' type='nominal' />
            <column-instance column='[delivery_days]' derivation='None' name='[none:delivery_days:qk]' pivot='key' type='quantitative' />
            <column caption='Order Delivered Customer Date' datatype='string' name='[order_delivered_customer_date]' role='dimension' type='nominal' />
            <column caption='Order Estimated Delivery Date' datatype='string' name='[order_estimated_delivery_date]' role='dimension' type='nominal' />
            <column caption='Order Id' datatype='string' name='[order_id]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <slices>
            <column>[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[none:Calculation_1391260503649083392:nk]</column>
            <column>[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[none:Calculation_1364520380846141440:nk]</column>
            <column>[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[none:delivery_days:qk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[cnt:order_id:qk]' value='n#,##0&quot; Orders&quot;;-#,##0&quot; Orders&quot;' />
            <format attr='color' field='[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[cnt:order_id:qk]' value='#61668d' />
            <format attr='font-weight' field='[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[cnt:order_id:qk]' value='bold' />
          </style-rule>
          <style-rule element='quick-filter'>
            <format attr='title' field='[federated.1cqwvyq0ibt9o216sbkq603qjvkn].[none:delivery_days:qk]' value='Delivery Days'>
              <formatted-text>
                <run bold='true' fontalignment='1' fontcolor='#61668d'>Delivery Days</run>
              </formatted-text>
            </format>
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
